<Window x:Class="zachet29._05.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор чаевых" Height="420" Width="430"
        ResizeMode="NoResize">

    <!-- Основная сетка с отступами -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Подпись и поле ввода суммы счёта -->
        <Label Grid.Row="0" Content="Сумма счёта (руб.):" Margin="0,0,0,2"/>
        <TextBox x:Name="textBoxBill" Grid.Row="1" Margin="0,0,0,12" Padding="5,4"/>

        <!-- Подпись и поле ввода количества гостей -->
        <Label Grid.Row="2" Content="Количество гостей:" Margin="0,0,0,2"/>
        <TextBox x:Name="textBoxGuests" Grid.Row="3" Margin="0,0,0,12" Padding="5,4"/>

        <!-- Группа переключателей для выбора процента чаевых -->
        <GroupBox Grid.Row="4" Header="Процент чаевых" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="10,8">
                <!-- Без чаевых — вариант по умолчанию -->
                <RadioButton x:Name="radioNone" Content="Без чаевых"
                             IsChecked="True" Margin="0,0,15,0"/>
                <RadioButton x:Name="radio5"    Content="5%"  Margin="0,0,15,0"/>
                <RadioButton x:Name="radio10"   Content="10%" Margin="0,0,15,0"/>
                <RadioButton x:Name="radio15"   Content="15%"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопка запуска расчёта -->
        <Button x:Name="buttonCalculate" Grid.Row="5"
                Content="Рассчитать"
                Width="130" HorizontalAlignment="Left"
                Padding="10,6" Margin="0,0,0,12"
                Click="buttonCalculate_Click"/>

        <!-- Область вывода результата -->
        <TextBlock x:Name="textBlockResult" Grid.Row="6"
                   TextWrapping="Wrap" FontSize="13" LineHeight="22"
                   Margin="0,4,0,0"/>
    </Grid>
</Window>